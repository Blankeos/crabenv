# ---- shared ----
DATABASE_URL="$(pwd)/local.db"

# ---- apps/cloudflare-worker/.env.example ----
PUBLIC_WORKER_ORIGIN=http://localhost:8788
WORKER_WEBHOOK_SECRET="$(openssl rand -hex 32)"
WORKER_KV_NAMESPACE=crabenv-fixture
WORKER_LOG_LEVEL=debug

# ---- apps/hono-api/.env.example ----
PUBLIC_API_ORIGIN=http://localhost:8787
HONO_API_PORT=8787
HONO_JWT_SECRET="$(openssl rand -base64 32)"
HONO_LOG_LEVEL=debug

# ---- apps/next-web/.env.example ----
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8787
AUTH_SECRET="$(openssl rand -base64 32)"
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
